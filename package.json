{
  "name": "personal-assistant",
  "version": "1.1.0",
  "description": "Max — a personal AI assistant for developers, built on the GitHub Copilot SDK",
  "bin": {
    "max": "dist/cli.js"
  },
  "files": [
    "dist/**/*.js",
    "skills/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "daemon": "tsx src/daemon.ts",
    "tui": "tsx src/tui/index.ts",
    "dev": "tsx --watch src/daemon.ts",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "copilot",
    "telegram",
    "orchestrator",
    "ai",
    "cli"
  ],
  "author": "Ryan Dsouza",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ryands17/personal-assistant.git"
  },
  "homepage": "https://github.com/ryands17/personal-assistant#readme",
  "bugs": {
    "url": "https://github.com/ryands17/personal-assistant/issues"
  },
  "type": "module",
  "dependencies": {
    "@github/copilot-sdk": "^0.1.26",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "grammy": "^1.40.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
